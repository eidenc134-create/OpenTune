<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.OpenTune" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowMinWidthMinor">100%</item>
        <item name="android:windowMinWidthMajor">100%</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">#ffffff</item>
        <item name="android:enforceNavigationBarContrast" tools:ignore="NewApi">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- COLORES PREMIUM NEOTUBE - ORO + NEGRO OSCURO -->
    <item name="colorPrimary">#FFD700</item>
    <item name="colorOnPrimary">#000000</item>
    <item name="colorSurface">#0A0A0A</item>
    <item name="colorOnSurface">#FFD700</item>
    <item name="colorAccent">#FFD700</item>
    <item name="android:statusBarColor">#0A0A0A</item>
    <item name="android:navigationBarColor">#0A0A0A</item>
    </style>
</resources>
